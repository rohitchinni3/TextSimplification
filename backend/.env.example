# ─────────────────────────────────────────────────────
# Text Simplification Backend — Environment Variables
# ─────────────────────────────────────────────────────

# Choose provider: "mock" or "mistral"
PROVIDER=mock

# ── Mistral Activation Steering Provider (only used when PROVIDER=mistral) ──
# Base URL of your Mistral-compatible model server (e.g. vLLM or TGI with steering support)
MISTRAL_BASE_URL=http://localhost:8080

# Model name as exposed by the server
MISTRAL_MODEL=mistral-7b-v0.1

# API key (if required by your model server)
MISTRAL_API_KEY=

# Steering layer index to apply activation vectors (model-architecture-dependent)
MISTRAL_STEERING_LAYER=16

# Initial coefficient for the simplification steering vector
MISTRAL_STEERING_COEFFICIENT=8.0

# How much to increase the coefficient per retry
MISTRAL_STEERING_COEFFICIENT_STEP=2.0

# Maximum retries before returning best result
MAX_ATTEMPTS=5
